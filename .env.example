# Environment Variables for GlobalDoc Connect
# Use this file as a template (do not commit your real `.env`).

# Database
# If your password contains special characters (e.g. `@`), URL-encode it (e.g. `@` -> `%40`).
DATABASE_URL=postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@YOUR_DB_HOST:5432/postgres

# Kora Payment Processing
KORA_SECRET_KEY=sk_test_REPLACE_ME
KORA_PUBLIC_KEY=pk_test_REPLACE_ME
# Optional
KORA_BASE_URL=https://api.korapay.com

# Agora Video SDK
AGORA_APP_ID=REPLACE_ME
AGORA_APP_CERTIFICATE=REPLACE_ME

# Browser video relay fallback (recommended for mobile networks, NAT, and facility routers)
# Example: turn:relay.example.com:3478,turns:relay.example.com:5349
VIDEO_TURN_URLS=
VIDEO_TURN_USERNAME=
VIDEO_TURN_CREDENTIAL=

# Supabase (client-exposed in Vite: OK to be public/anon keys only)
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_KEY=eyJ...YOUR_ANON_PUBLIC_KEY...
# When using Vercel, set these in the Vercel dashboard for production.
# Also register the callback URL at https://globaldoctorplatform.vercel.app/auth/callback

# API Configuration
# Local dev typically runs the API on `http://localhost:4000`.
VITE_API_BASE=http://localhost:4000
PORT=4000
APP_TIME_ZONE=Africa/Lagos
# Keep false in production unless actively diagnosing a deployment.
RUN_STARTUP_DIAGNOSTICS=false
# Optional server-side provider request limits in milliseconds.
SUPABASE_HTTP_TIMEOUT_MS=7000
KORA_HTTP_TIMEOUT_MS=6500

# Security (server-only)
JWT_SECRET=REPLACE_ME
BCRYPT_ROUNDS=12
ADMIN_EMAIL=shafiuabdullahi.sa3@gmail.com
ADMIN_PASSWORD=014/Pt/014

# Email Service (server-only)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-account@gmail.com
# Gmail requires a 16-letter App Password created after enabling 2-Step Verification.
# Spaces are accepted, but do not use a Google OAuth client ID or your normal Gmail password.
SMTP_PASS=abcd efgh ijkl mnop
SMTP_FROM=your-account@gmail.com
SMTP_FROM_NAME=GlobalDoc Connect
# Optional OAuth2 alternative. All three values are required; a Client ID alone cannot authenticate SMTP.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Compliance
DATA_RETENTION_YEARS=7
AUDIT_LOG_RETENTION_YEARS=10
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_KEY

# Social Media Handles (client-exposed in Vite)
VITE_SOCIAL_TWITTER=https://x.com/globaldocconnect
VITE_SOCIAL_FACEBOOK=https://facebook.com
VITE_SOCIAL_INSTAGRAM=https://instagram.com
VITE_SOCIAL_TELEGRAM=https://t.me
VITE_SOCIAL_SNAPCHAT=https://snapchat.com
VITE_SOCIAL_TIKTOK=https://tiktok.com
VITE_SOCIAL_YOUTUBE=https://youtube.com
